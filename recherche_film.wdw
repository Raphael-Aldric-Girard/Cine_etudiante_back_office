  -
    name : BTN_Enregistrer
    identifier : 0x29c18b5002e5b123
    internal_properties : 
    properties :
     x : 183
     y : 652
     width : 204
     height : 31
     accelerator_key : 65535
     tab_order : 4
    style : {}
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         si OuiNon(BTN_Enregistrer,"voulez-vous enregistrer ce film?") alors
         
         
         
         	si HOuvreConnexion(MaConnexion1) alors
         		HChangeConnexion(film,MaConnexion1)
         
         		// on va vérifier si le film est déjà en base
         		hlitPremier(film)
         		tantque Htrouve() = 1
         			si film.title = table_infos.Titre ALORS
         				Erreur("film déjà en base")
         				sortir
         			sinon
         				HLitSuivant()
         			FIN
         		FIN
         
         
         
         		film.title			= table_infos.Titre
         		film.overview		= table_infos.overview
         		film.poster_path	= table_infos.posterpath
         		film.original_title	= table_infos.original_title
         
         		si HAjoute(film) = Faux alors
         			Trace(HErreurInfo())
         		fin
         
         		HFermeConnexion(MaConnexion1)
         
         		info("film bien enregistré")
         
         	sinon
         		Erreur("erreur lors de la connexion")
         	fin
         FIN
         
         
         
        type : 18
      -
        type : 161
        enabled : false
